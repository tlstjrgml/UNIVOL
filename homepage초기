<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>UNIVOL</title>

<style>
body {
    margin: 0;
  
    font-family: Arial, sans-serif;
}

/* 전체 박스 */


/* 공통 줄 */
.row {
    position: relative;
    height: 90px;
}

/* 중앙 박스 */
.center-box {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 60px;
    border: 2px solid #aaa;
    border-radius: 10px;
    font-weight: bold;
    background: #fff;
    z-index: 1;
}

.title {
    border: none;          /* 테두리 제거 */
    font-size: 32px;       /* 글자 크게 */
    padding: 0;            /* 여백 제거 (텍스트 느낌) */
    color: #426B1F;      /* 초록색 */
    cursor: pointer;
}

/* 오른쪽 메뉴 */
.menu {
    position: absolute;
    right: 0;
    top: 20px;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 10px;
}

/* 버튼 */
button {
    padding: 8px 14px;
    border: 1px solid #aaa;
    background: white;
    border-radius: 6px;
    cursor: pointer;
}

button:hover {
    background: #eee;
}

/* 카드 */
.card {
    width: 80%;
    margin: 30px auto;
    height: 200px;
    border: 2px solid #bbb;
    border-radius: 12px;
    display: flex;
    justify-content: center;
    align-items: center;
    color: #555;
}
</style>
</head>

<body>

<div class="container">

    <!-- 1줄 (UNIVOL + 로그인/회원가입) -->
    <div class="row">
        <div class="center-box title">UNIVOL</div>

        <div class="menu">
            <button>로그인</button>
            <button>회원가입</button>
            <button>마이페이지</button>
        </div>
    </div>

    <!-- 2줄 (게시판 + 마이페이지) -->
    <div class="row">
        <div class="center-box">게시판</div>

    
    </div>

    <!-- 카드 -->
    <div class="card">
        봉사 게시판 최근게시물 5개
    </div>

    <div class="card">
        후기 게시판 최근게시물 5개
    </div>

</div>

</body>
</html>

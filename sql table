CREATE TABLE "USER" (
    USER_ID     VARCHAR2(20) NOT NULL,
    USER_NAME   VARCHAR2(20) NOT NULL,
    AGE         NUMBER,
    GENDER      CHAR(1) DEFAULT 'M' NOT NULL,
    PHONE       VARCHAR2(20),
    ADDRESS     VARCHAR2(50),
    IS_ADMIN    CHAR(1) DEFAULT 'N' NOT NULL,
    
    CONSTRAINT PK_USER PRIMARY KEY (USER_ID),
    CONSTRAINT CK_USER_GENDER CHECK (GENDER IN ('M', 'F')),
    CONSTRAINT CK_USER_IS_ADMIN CHECK (IS_ADMIN IN ('Y', 'N'))
);


CREATE TABLE POST (
    P_NUMBER    NUMBER NOT NULL,
    P_TITLE     VARCHAR2(200) NOT NULL,
    CONTENTS    CLOB NOT NULL,
    VIEWS       NUMBER DEFAULT 0,
    P_DATE      DATE DEFAULT SYSDATE,
    TYPE        CHAR(1) NOT NULL,
    USER_ID     VARCHAR2(20) NOT NULL,
    
    CONSTRAINT PK_POST PRIMARY KEY (P_NUMBER),
    CONSTRAINT CK_POST_TYPE CHECK (TYPE IN ('V', 'R')),
    CONSTRAINT FK_POST_TO_USER FOREIGN KEY (USER_ID)
        REFERENCES "USER" (USER_ID)
);


CREATE TABLE VOLUNTEER (
    P_NUMBER    NUMBER NOT NULL,
    V_TITLE     VARCHAR2(200) NOT NULL,
    V_DATE      DATE NOT NULL,
    V_PLACE     VARCHAR2(50),
    
    CONSTRAINT PK_VOLUNTEER PRIMARY KEY (P_NUMBER),
    CONSTRAINT FK_POST_TO_VOLUNTEER_1 FOREIGN KEY (P_NUMBER)
        REFERENCES POST (P_NUMBER)
);


CREATE TABLE "COMMENT" (
    C_NUMBER    NUMBER NOT NULL,
    COMMENTS    CLOB NOT NULL,
    C_DATE      DATE DEFAULT SYSDATE NOT NULL,
    P_NUMBER    NUMBER NOT NULL,
    USER_ID     VARCHAR2(20) NOT NULL,
    
    CONSTRAINT PK_COMMENT PRIMARY KEY (C_NUMBER),
    CONSTRAINT FK_COMMENT_TO_POST FOREIGN KEY (P_NUMBER)
        REFERENCES POST (P_NUMBER),
    CONSTRAINT FK_COMMENT_TO_USER FOREIGN KEY (USER_ID)
        REFERENCES "USER" (USER_ID)
);


CREATE TABLE P_LIKE (
    USER_ID     VARCHAR2(20) NOT NULL,
    P_NUMBER    NUMBER NOT NULL,
    
    CONSTRAINT PK_P_LIKE PRIMARY KEY (USER_ID, P_NUMBER),
    CONSTRAINT FK_USER_TO_P_LIKE_1 FOREIGN KEY (USER_ID)
        REFERENCES "USER" (USER_ID),
    CONSTRAINT FK_POST_TO_P_LIKE_1 FOREIGN KEY (P_NUMBER)
        REFERENCES POST (P_NUMBER)
);


CREATE TABLE APPLY (
    A_NUMBER    NUMBER NOT NULL,
    A_STATE     CHAR(1) DEFAULT 'N',
    USER_ID     VARCHAR2(20) NOT NULL,
    P_NUMBER    NUMBER NOT NULL,
    
    CONSTRAINT PK_APPLY PRIMARY KEY (A_NUMBER),
    CONSTRAINT CK_APPLY_STATE CHECK (A_STATE IN ('Y', 'N')),
    CONSTRAINT FK_APPLY_TO_USER FOREIGN KEY (USER_ID)
        REFERENCES "USER" (USER_ID),
    CONSTRAINT FK_APPLY_TO_POST FOREIGN KEY (P_NUMBER)
        REFERENCES POST (P_NUMBER)
);


CREATE TABLE C_LIKE (
    USER_ID     VARCHAR2(20) NOT NULL,
    C_NUMBER    NUMBER NOT NULL,
    
    CONSTRAINT PK_C_LIKE PRIMARY KEY (USER_ID, C_NUMBER),
    CONSTRAINT FK_USER_TO_C_LIKE_1 FOREIGN KEY (USER_ID)
        REFERENCES "USER" (USER_ID),
    CONSTRAINT FK_COMMENT_TO_C_LIKE_1 FOREIGN KEY (C_NUMBER)
        REFERENCES "COMMENT" (C_NUMBER)
);

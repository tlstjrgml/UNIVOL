CREATE TABLE USERS (
    USER_ID     VARCHAR2(20),
    USER_NAME   VARCHAR2(20)    NOT NULL,
    AGE         NUMBER,
    GENDER      CHAR(1)         NOT NULL,
    PHONE       VARCHAR2(20),
    ADDRESS     VARCHAR2(50),
    IS_ADMIN    CHAR(1)         DEFAULT 'N' NOT NULL,

    CONSTRAINT PK_USERS         PRIMARY KEY (USER_ID),
    CONSTRAINT CK_USERS_GENDER  CHECK (GENDER   IN ('M', 'F')),
    CONSTRAINT CK_USERS_ADMIN   CHECK (IS_ADMIN IN ('Y', 'N'))
);

CREATE TABLE POST (
    P_NUMBER    NUMBER GENERATED BY DEFAULT AS IDENTITY,
    P_TITLE     VARCHAR2(200)   NOT NULL,
    CONTENTS    CLOB            NOT NULL,
    VIEWS       NUMBER          DEFAULT 0,
    P_DATE      DATE            DEFAULT SYSDATE,
    P_TYPE      CHAR(1)         NOT NULL,
    USER_ID     VARCHAR2(20)    NOT NULL,

    CONSTRAINT PK_POST       PRIMARY KEY (P_NUMBER),
    CONSTRAINT CK_POST_TYPE  CHECK (P_TYPE IN ('V', 'R')),
    CONSTRAINT FK_POST_USER  FOREIGN KEY (USER_ID) REFERENCES USERS (USER_ID)
);

CREATE TABLE VOLUNTEER (
    P_NUMBER    NUMBER,
    V_TITLE     VARCHAR2(200)   NOT NULL,
    V_DATE      DATE            NOT NULL,
    V_PLACE     VARCHAR2(50),

    CONSTRAINT PK_VOLUNTEER       PRIMARY KEY (P_NUMBER),
    CONSTRAINT FK_VOLUNTEER_POST  FOREIGN KEY (P_NUMBER) REFERENCES POST (P_NUMBER)
);

CREATE TABLE REPLY (
    C_NUMBER    NUMBER GENERATED BY DEFAULT AS IDENTITY,
    COMMENTS    CLOB            NOT NULL,
    C_DATE      DATE            DEFAULT SYSDATE NOT NULL,
    P_NUMBER    NUMBER          NOT NULL,
    USER_ID     VARCHAR2(20)    NOT NULL,

    CONSTRAINT PK_REPLY       PRIMARY KEY (C_NUMBER),
    CONSTRAINT FK_REPLY_POST  FOREIGN KEY (P_NUMBER) REFERENCES POST  (P_NUMBER),
    CONSTRAINT FK_REPLY_USER  FOREIGN KEY (USER_ID)  REFERENCES USERS (USER_ID)
);

CREATE TABLE P_LIKE (
    USER_ID     VARCHAR2(20)    NOT NULL,
    P_NUMBER    NUMBER          NOT NULL,

    CONSTRAINT PK_P_LIKE       PRIMARY KEY (USER_ID, P_NUMBER),
    CONSTRAINT FK_P_LIKE_USER  FOREIGN KEY (USER_ID)  REFERENCES USERS (USER_ID),
    CONSTRAINT FK_P_LIKE_POST  FOREIGN KEY (P_NUMBER) REFERENCES POST  (P_NUMBER)
);

CREATE TABLE APPLY (
    A_NUMBER    NUMBER GENERATED BY DEFAULT AS IDENTITY,
    A_STATE     CHAR(1)         DEFAULT 'N' NOT NULL,
    USER_ID     VARCHAR2(20)    NOT NULL,
    P_NUMBER    NUMBER          NOT NULL,

    CONSTRAINT PK_APPLY         PRIMARY KEY (A_NUMBER),
    CONSTRAINT UQ_APPLY_USER_POST UNIQUE (USER_ID, P_NUMBER),
    CONSTRAINT CK_APPLY_STATE   CHECK (A_STATE IN ('Y', 'N')),
    CONSTRAINT FK_APPLY_USER    FOREIGN KEY (USER_ID)  REFERENCES USERS (USER_ID),
    CONSTRAINT FK_APPLY_POST    FOREIGN KEY (P_NUMBER) REFERENCES POST  (P_NUMBER)
);

CREATE TABLE C_LIKE (
    USER_ID     VARCHAR2(20)    NOT NULL,
    C_NUMBER    NUMBER          NOT NULL,

    CONSTRAINT PK_C_LIKE        PRIMARY KEY (USER_ID, C_NUMBER),
    CONSTRAINT FK_C_LIKE_USER   FOREIGN KEY (USER_ID)  REFERENCES USERS (USER_ID),
    CONSTRAINT FK_C_LIKE_REPLY  FOREIGN KEY (C_NUMBER) REFERENCES REPLY (C_NUMBER)
);
